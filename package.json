{
  "name": "@mlightcad/ribbon",
  "version": "0.0.3",
  "packageManager": "pnpm@10.33.0",
  "type": "module",
  "main": "./dist/ml-ribbon.es.js",
  "module": "./dist/ml-ribbon.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/ml-ribbon.es.js",
      "default": "./dist/ml-ribbon.es.js"
    },
    "./style.css": {
      "default": "./dist/ml-ribbon.css"
    }
  },
  "files": [
    "dist/*.js",
    "dist/*.css",
    "dist/**/*.d.ts",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build --mode lib && pnpm build:types",
    "build:types": "vue-tsc -p tsconfig.types.json",
    "build:demo": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "prepublishOnly": "pnpm build && pnpm test"
  },
  "peerDependencies": {
    "@element-plus/icons-vue": "^2.3.2",
    "element-plus": "^2.12.0",
    "vue": "^3.4.21"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@element-plus/icons-vue": "^2.3.2",
    "@playwright/test": "^1.56.1",
    "@testing-library/vue": "^8.1.0",
    "@types/node": "^24.12.2",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.2.0",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.5.0",
    "jsdom": "^29.0.2",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.1",
    "vite": "^8.0.4",
    "vitest": "^4.1.4",
    "vue": "^3.4.21",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^3.2.6",
    "element-plus": "^2.12.0"
  }
}
